<UserControl x:Class="Turn_One_Link.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="20,12,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- User greeting -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="GreetingText" Text="Welcome back"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock x:Name="UserNameText" Text="Driver"
                           FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                           Foreground="White" Margin="0,1,0,0"/>
            </StackPanel>
            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                    Content="Sign out" VerticalAlignment="Top"
                    Click="SignOutButton_Click"/>
        </Grid>

        <!-- Sim Game connection card -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="SIM GAME" FontFamily="Segoe UI" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>

                <StackPanel Grid.Row="0" Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
        
                    <TextBlock x:Name="SimStatusLabel" 
                               Text="Disconnected"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/> <Grid VerticalAlignment="Center">
                        <Ellipse x:Name="SimGlowDot" Width="24" Height="24" Opacity="0.4" Fill="Red">
                            <Ellipse.Effect>
                                <BlurEffect Radius="12"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="SimStatusDot" Width="8" Height="8" Fill="Red"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <TextBlock x:Name="SimGameName" Grid.Row="2" Grid.Column="0"
                           Text="No game detected"
                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                           Foreground="White"/>
            </Grid>
        </Border>

        <!-- TurnOne Server connection card -->
        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="TURN ONE SERVERS" FontFamily="Segoe UI" FontSize="10"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <StackPanel Grid.Row="0" Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    
                    <TextBlock x:Name="ServerStatusLabel" 
                               Text="Online"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <Grid VerticalAlignment="Center">
                        <Ellipse x:Name="ServerGlowDot" Width="24" Height="24" Opacity="0.4" Fill="#FF00FF7F">
                            <Ellipse.Effect>
                                <BlurEffect Radius="12"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="ServerStatusDot" Width="8" Height="8" Fill="#FF00FF7F"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <TextBlock x:Name="ServerStatusText" Grid.Row="2" Grid.Column="0"
                           Text="Connected"
                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                           Foreground="White"/>
            </Grid>
        </Border>

        <!-- Version -->
        <TextBlock Grid.Row="6" HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   Text="v0.0.1" FontFamily="Segoe UI" FontSize="10"
                   Foreground="#33FFFFFF"/>
    </Grid>
</UserControl>
